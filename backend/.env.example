# ── Django core ───────────────────────────────────────────────────────────────
DJANGO_SECRET_KEY=change-me-to-a-long-random-string
DJANGO_DEBUG=true
ALLOWED_HOSTS=localhost,127.0.0.1

# ── Database ──────────────────────────────────────────────────────────────────
# Leave DATABASE_URL empty to use the local SQLite file under backend/data/.
# DATABASE_URL=postgresql://user:pass@host:5432/dbname
# SQLITE_PATH=
# DATA_DIR=

# ── REST API / JWT ────────────────────────────────────────────────────────────
# JWT_ACCESS_MINUTES=60
JWT_REFRESH_DAYS=30
TABLE_PRICE_ILS=2.5
COMMISSION_ILS=5.0

TABLE_PRICE_ILS=2.5
COMMISSION_ILS=5.0

# ── CORS: origins of the React/Next.js frontend ───────────────────────────────
# On Railway set FRONTEND_URL=https://your-frontend.up.railway.app
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
CSRF_TRUSTED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# ── Admin ─────────────────────────────────────────────────────────────────────
ADMIN_EMAIL=admin@admin.com
# Superuser קבוע — נוצר אוטומטית אחרי migrate, סיסמה תמיד admin
BOOTSTRAP_ADMIN_EMAIL=admin@admin.com
BOOTSTRAP_ADMIN_PASSWORD=admin
BOOTSTRAP_ADMIN_ENABLED=true

# ── Resend — אימות אימייל בהרשמה (רק ב-Backend!) ─────────────────────────────
# https://api.resend.com/emails — דומיין חייב להיות מאומת ב-Resend
# RESEND_API_KEY=re_xxxxxxxx
# RESEND_FROM_EMAIL=Mandeles <noreply@mandeles.co.il>
# EMAIL_VERIFICATION_HOURS=24
# FRONTEND_URL=http://localhost:3000
# אותו ערך גם ב-frontend/.env.local — שליחת מייל מ-Next אם אין Resend ב-Backend
# EMAIL_PROXY_SECRET=change-me-long-random-string

# ── SMS OTP (אימות טלפון) ─────────────────────────────────────────────────────
# SMS_VERIFICATION_ENABLED=true
# SMS_PROVIDER=log
# log = חינם בפיתוח (קוד בלוגי Backend). twilio = production (ניסיון חינם ~$15)
# SMS_OTP_MINUTES=10
# TWILIO_ACCOUNT_SID=
# TWILIO_AUTH_TOKEN=
# TWILIO_FROM_NUMBER=+15005550006

# ── Firebase Phone Auth (Railway Backend + אימות טלפון אחרי אימייל) ─────────
# 1) Firebase Console → Project settings → Service accounts → Generate new private key
# 2) הדבק את כל קובץ ה-JSON בשורה אחת (או multiline ב-Railway):
# FIREBASE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"mendeles-79320",...}
# לחלופין: FIREBASE_SERVICE_ACCOUNT_JSON_BASE64=<base64 של הקובץ>
PHONE_VERIFICATION_ENABLED=true

# ── iCount — הנפקת חשבוניות (Railway: שירות Backend בלבד) ─────────────────────
# חובה — טוקן API (iCount → הגדרות → API):
# ICOUNT_API_TOKEN=API3E8-...
# מומלץ — מזהה חברה (cid), למשל mendeles:
# ICOUNT_COMP_ID=mendeles
# לא נדרש עם טוקן — התחברות ישנה (אימייל+סיסמה):
# ICOUNT_USER=your@email.com
# ICOUNT_PASSWORD=
# ICOUNT_API_URL=https://api.icount.co.il/api/v3.php
# ICOUNT_DOC_TYPE=auto
# auto = בוחר אוטומטית (ברירת מחדל: receipt אם קיים)
# receipt = קבלה (נוסף תשלום מזומן אוטומטית) | order | deal | offer
# invrec/invoice — רק אם מופעלים ב-iCount שלך
# ICOUNT_VAT_RATE=18

# ── Print server (הדפסת סיכום הזמנה) ─────────────────────────────────────────
# POST מלא (מומלץ) + x-api-key:
# PRINT_SERVER_URL=https://battered-festivity-domelike.ngrok-free.dev/print
# חשוב: ngrok משתמש ב-.dev (לא .app) — אותו שם מנהרה, סיומת שונה
# PRINT_API_KEY=...
# PRINT_API_KEY_HEADER=x-api-key
# PRINT_PAYLOAD_MODE=forms   ← id,name,phone,forms (לפי אדם) | pdf_url ← {"pdf_url":"..."}
# PRINT_PATH=/print          ← רק אם PRINT_SERVER_URL בלי /print בסוף
# ב-Railway: הדבק את כל JSON בשורה אחת או כ-multiline variable
#
# ── זרימת הדפסה + סריקה (tools/scan_app.py) ─────────────────────────────────
# 1) אדמין שולח להדפסה → printing / printed (אם המדפסת אישרה)
# 2) אחרי הדפסה מוצלחת — שרת מדפסת: POST {Frontend}/api/print/confirm
#    headers: x-api-key: PRINT_API_KEY  body: { orderId, printedAt }  → printed
#    עזר: python tools/print_confirm.py <order_id> <order_number>
# 3) אפליקציית סריקה GET /api/print/orders/?status=printed
# 4) העלאת PDF POST /api/print/scan/ → completed + הלקוח רואה בפרופיל
# PRINT_API_KEY משמש גם לסוכן ההדפסה (print_agent) ולאפליקציית הסריקה (אותו מפתח)

# תור הדפסה בענן (24/7) — הזמנות נכנסות אוטומטית; סוכן מקומי מושך מאושרות
# PRINT_QUEUE_AUTO_ENQUEUE=true
# PRINT_AGENT_ONLINE_SECONDS=90

# ── Optional: Stripe wallet topup ─────────────────────────────────────────────
# When set, POST /api/wallet/topup/ creates a Stripe PaymentIntent.
# Without it, dev mode credits the wallet immediately.
# STRIPE_SECRET_KEY=sk_test_...
# pip install stripe

# ── Optional features (default on — toggle at runtime via /admin/services) ─────
PORTAL_DASHBOARD_ENABLED=true
AI_AGENT_ENABLED=true
# GEMINI_API_KEY=
# GITHUB_TOKEN=          # required for AI stages 2–3 (PR + merge)
# GITHUB_REPO=owner/repo # e.g. ihabah1/mendeles-next
