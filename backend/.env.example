# ── Django core ───────────────────────────────────────────────────────────────
DJANGO_SECRET_KEY=change-me-to-a-long-random-string
DJANGO_DEBUG=true
ALLOWED_HOSTS=localhost,127.0.0.1

# ── Database ──────────────────────────────────────────────────────────────────
# Leave DATABASE_URL empty to use the local SQLite file under backend/data/.
# DATABASE_URL=postgresql://user:pass@host:5432/dbname
# SQLITE_PATH=
# DATA_DIR=

# ── REST API / JWT ────────────────────────────────────────────────────────────
# JWT_ACCESS_MINUTES=60
JWT_REFRESH_DAYS=30
TABLE_PRICE_ILS=2.5
COMMISSION_ILS=5.0

TABLE_PRICE_ILS=2.5
COMMISSION_ILS=5.0

# ── CORS: origins of the React/Next.js frontend ───────────────────────────────
# On Railway set FRONTEND_URL=https://your-frontend.up.railway.app
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
CSRF_TRUSTED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# ── Admin ─────────────────────────────────────────────────────────────────────
ADMIN_EMAIL=admin@admin.com
# Superuser קבוע — נוצר אוטומטית אחרי migrate, סיסמה תמיד admin
BOOTSTRAP_ADMIN_EMAIL=admin@admin.com
BOOTSTRAP_ADMIN_PASSWORD=admin
BOOTSTRAP_ADMIN_ENABLED=true

# ── Resend — אימות אימייל בהרשמה (רק ב-Backend!) ─────────────────────────────
# https://api.resend.com/emails — דומיין חייב להיות מאומת ב-Resend
# RESEND_API_KEY=re_xxxxxxxx
# RESEND_FROM_EMAIL=Mandeles <noreply@mandeles.co.il>
# EMAIL_VERIFICATION_HOURS=24
# FRONTEND_URL=http://localhost:3000
# אותו ערך גם ב-frontend/.env.local — שליחת מייל מ-Next אם אין Resend ב-Backend
# EMAIL_PROXY_SECRET=change-me-long-random-string

# ── SMS OTP (אימות טלפון) ─────────────────────────────────────────────────────
# SMS_VERIFICATION_ENABLED=true
# SMS_PROVIDER=log
# log = חינם בפיתוח (קוד בלוגי Backend). twilio = production (ניסיון חינם ~$15)
# SMS_OTP_MINUTES=10
# TWILIO_ACCOUNT_SID=
# TWILIO_AUTH_TOKEN=
# TWILIO_FROM_NUMBER=+15005550006

# ── Firebase Phone Auth (מומלץ ל-production) ───────────────────────────────────
# FIREBASE_SERVICE_ACCOUNT_JSON={"type":"service_account",...}
# ב-Railway: הדבק את כל JSON בשורה אחת או כ-multiline variable

# ── Optional: Stripe wallet topup ─────────────────────────────────────────────
# When set, POST /api/wallet/topup/ creates a Stripe PaymentIntent.
# Without it, dev mode credits the wallet immediately.
# STRIPE_SECRET_KEY=sk_test_...
# pip install stripe

# ── Optional features (default on — toggle at runtime via /admin/services) ─────
PORTAL_DASHBOARD_ENABLED=true
AI_AGENT_ENABLED=true
# GEMINI_API_KEY=
# GITHUB_TOKEN=          # required for AI stages 2–3 (PR + merge)
# GITHUB_REPO=owner/repo # e.g. ihabah1/mendeles-next
