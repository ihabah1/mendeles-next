# ── Django core ───────────────────────────────────────────────────────────────
DJANGO_SECRET_KEY=change-me-to-a-long-random-string
DJANGO_DEBUG=true
ALLOWED_HOSTS=localhost,127.0.0.1

# ── Database ──────────────────────────────────────────────────────────────────
# Leave DATABASE_URL empty to use the local SQLite file under backend/data/.
# DATABASE_URL=postgresql://user:pass@host:5432/dbname
# SQLITE_PATH=
# DATA_DIR=

# ── REST API / JWT ────────────────────────────────────────────────────────────
# JWT_ACCESS_MINUTES=60
JWT_REFRESH_DAYS=30
TABLE_PRICE_ILS=2.5
COMMISSION_ILS=5.0

TABLE_PRICE_ILS=2.5
COMMISSION_ILS=5.0

# ── CORS: origins of the React/Next.js frontend ───────────────────────────────
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
CSRF_TRUSTED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# ── Admin ─────────────────────────────────────────────────────────────────────
ADMIN_EMAIL=admin@admin.com
# Superuser קבוע — נוצר אוטומטית אחרי migrate, סיסמה תמיד admin
BOOTSTRAP_ADMIN_EMAIL=admin@admin.com
BOOTSTRAP_ADMIN_PASSWORD=admin
BOOTSTRAP_ADMIN_ENABLED=true

# ── Optional: Stripe wallet topup ─────────────────────────────────────────────
# When set, POST /api/wallet/topup/ creates a Stripe PaymentIntent.
# Without it, dev mode credits the wallet immediately.
# STRIPE_SECRET_KEY=sk_test_...
# pip install stripe

# ── Optional features (default on — toggle at runtime via /admin/services) ─────
PORTAL_DASHBOARD_ENABLED=true
AI_AGENT_ENABLED=true
# GEMINI_API_KEY=
# GITHUB_TOKEN=
# GITHUB_REPO=owner/repo
