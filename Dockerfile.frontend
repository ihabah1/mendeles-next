# Frontend deploy from REPO ROOT (Railway Root Directory empty).
# If Root Directory = frontend, use frontend/Dockerfile instead.
FROM node:20-alpine

WORKDIR /app

COPY frontend/package.json frontend/package-lock.json ./
RUN npm ci

COPY frontend/ .

ENV NEXT_TELEMETRY_DISABLED=1
ENV NODE_ENV=production

RUN npm run build

EXPOSE 3000
ENV HOSTNAME=0.0.0.0

CMD ["npm", "start"]
